function void MSMKI.BaseUpdate()
{
	//DEZ1 Mecha MK. I Boss
	if(System.getGlobalVariableValueByName("MSMKI.WarioDoorFrame") > 0)
		Wario.BossStartLaugh()
	base.MSMKI.BaseUpdate()
}

