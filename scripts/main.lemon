	base.fn07764e()
}

function void EggmanBlue.BossStartLaugh()
{
	EggmanBlue.BossStartLaughValue(64)
}

function void EggmanBlue.BossStartLaughValue(u8 value)
{
	if(EggmanBlue.bossInit > 1) 
	{
		EggmanBlue.bossInit--
		return
	}
	else if(EggmanBlue.bossInit > 0) 
	{
		EggmanBlue.bossInit--
		if(EggmanBlue.disableEventLaugh != 1)
			if(EggmanBlue.laughTimer < value) 
				EggmanBlue.laughTimer = value 
	}
	return
}

//# address-hook(0x0691c8) end(0x069222)
function void fn0691c8()
{
	//AIZ2 Boss
	u16 positionX = u16[0xfffffa82]
	if (positionX > camera.position.x.u16)
		return

	EggmanBlue.bossInit = 1
	base.fn0691c8()
}

