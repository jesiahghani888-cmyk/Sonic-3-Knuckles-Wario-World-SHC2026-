#if STANDALONE

include shc_splash

global u8 Wario.bossInit = 0
global u8 Wario.laughTimer = 0
global s16 Wario.lastXPos = 0
global u8 Wario.golemRemaining_hits = 0
global u16 Wario.lastFrame = 0

function void Wario.setLaughTimerForEvent(u8 value) 
{
	if(Wario.disableEventLaugh != 1) 
	{
		Wario.laughTimer = value
	}
}

function bool Wario.onWriteToSpriteTable(s16 px, s16 py, u16 renderQueue)
{	
	//Normal Eggmobile Bosses
	if(objA0.update_address == 0x067b66 || objA0.update_address == 0x067aca || objA0.update_address == 0x067c38 || objA0.update_address == 0x067cd2)
    {
		if(objA0.mapping_offset != 0x0681d4) //Not Eggrobo
		{
			u64 key = 0x00
			u8 animationSprite = objA0.animation.sprite
			if(objA0.animation.sprite < 0x02)
			{
				Wario.lastXPos = 0
				if(Wario.showRegular())
				{
					
					if (global.zone_act == 0x0601 && camera.position.y.u16 == 0x0668)
						key = stringformat("wario-blue-%02x", Wario.getFreezableMetronome())
					//Egg Golem Escape
					else if (global.zone_act == 0x0801 && Wario.golemRemaining_hits == 0 && Wario.burnType > 0) 
					{
						u8 frame = Wario.getFreezableMetronome()
						key = stringformat("wario-blue-brn-%02x", (frame + (2 * Wario.burnType)))
					}
					else
						key = stringformat("wario-blue-%02x", animationSprite)
				}
				else
				{
					key = stringformat("wario-laugh-blue-%02x", (Wario.getMetronome() + (Wario.laughStyle * 0x02)))
				}
			}
			else if(objA0.animation.sprite == 0x03)
			{
				s16 xPos = camera.position.x.u16 + px
				if(Wario.burnType > 0 && Wario.lastXPos != 0)
				{
					if((objA0.render_flags & render_flag.FLIP_X) ? (xPos > Wario.lastXPos) : (xPos < Wario.lastXPos))
					{
						if(global.zone_act != 0x0701 || camera.position.x.u16 < 0x4000 || camera.position.x.u16 > 0x4400) 
						{
							u8 frame = Wario.getFreezableMetronome()
							key = stringformat("wario-blue-brn-%02x", (frame + (2 * Wario.burnType)))
						}
					}
				}
				if(key == 0x00)
				{
					key = stringformat("wario-blue-%02x", animationSprite)
				}
				Wario.lastXPos = xPos
			}
			else 
			{
				if(objA0.animation.sprite == 0x02)
				{
					animationSprite += Wario.hurtAlign
					if(global.zone_act != 0x00160 || camera.position.x.u16 < 0x001700)
						Wario.laughTimer = 0
				}
				key = stringformat("wario-blue-%02x", animationSprite)
			}
			if(Wario.spritesType)
			{
				key = stringformat("%s-png", key)
			}
			if(key != 0x00 && Renderer.hasCustomSprite(key))
			{
				bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
				Renderer.drawCustomSprite(key, px, py, Wario.getDefaultPal(), (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
				return true
			}
		}
    }
	
	//FBZ2 Second Boss
	else if (objA0.update_address == 0x067b96)
	{
		if(!isMainCharacter(CHARACTER_KNUCKLES))
		{
			u64 key = 0x00
			if(objA0.animation.sprite < 0x02)
			{
				Wario.lastXPos = 0
				if(Wario.showRegular())
					key = stringformat("wario-fbz-blue-%02x", (objA0.animation.sprite + Wario.getFreezableMetronome() * 0x04))
				else 
					key = stringformat("wario-laugh-fbz-blue-%02x", (Wario.getMetronome() + (Wario.laughStyle * 0x02)))
			}
			else if(objA0.animation.sprite == 0x03)
			{
				s16 xPos = camera.position.x.u16 + px
				if(Wario.burnType > 0 && Wario.lastXPos != 0)
				{
					if((objA0.render_flags & render_flag.FLIP_X) ? (xPos > Wario.lastXPos) : (xPos < Wario.lastXPos))
					{
						u8 frame = Wario.getFreezableMetronome()
						key = stringformat("wario-blue-brn-%02x", (frame + (2 * Wario.burnType)))
					}
				}
				if(key == 0x00)
				{
					key = stringformat("wario-fbz-blue-%02x", objA0.animation.sprite)
				}
				Wario.lastXPos = xPos
			}
			else 
			{
				if(objA0.animation.sprite == 0x02)
				{
					Wario.laughTimer = 0
				}
				key = stringformat("wario-fbz-blue-%02x", objA0.animation.sprite)
			}
			if(Wario.spritesType)
			{
				key = stringformat("%s-png", key)
			}
			if(key != 0x00 && Renderer.hasCustomSprite(key))
			{
				bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
				Renderer.drawCustomSprite(key, px, py, Wario.getDefaultPal(), (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
				return true
			}
		}
	}
	
	//LRZ2 Boss
	else if (objA0.update_address == 0x079c1c)
	{
		u64 key = 0x00
		if(objA0.animation.sprite == 0x0f)
		{
			if(Wario.showRegular())
				key = stringformat("wario-lrz-blue-%02x", (objA0.animation.sprite + Wario.getFreezableMetronome() * 0x03))
			else
				key = stringformat("wario-laugh-lrz-blue-%02x", (Wario.getMetronome() + (Wario.laughStyle * 0x02)))
		}
		else 
		{
			if(objA0.animation.sprite == 0x10)
			{
				Wario.laughTimer = 0
			}
			key = stringformat("wario-lrz-blue-%02x", objA0.animation.sprite)
		}
		if(Wario.spritesType)
		{
			key = stringformat("%s-png", key)
		}
		if(key != 0x00 && Renderer.hasCustomSprite(key))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, Wario.getDefaultPal(), (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			return true
		}
	}
	
	//FBZ2 Mini Boss and DEZ2 Boss
	else if (objA0.update_address == 0x070068 || objA0.update_address == 0x07009a) 
	{
		if(objA0.mapping_offset != 0x186bb0) //Not Eggrobo
		{
			u64 key = 0x00
			if(objA0.animation.sprite < 0x02)
			{
				if(Wario.showRegular())
					key = stringformat("wario-fbz-mini-blue-%02x", objA0.animation.sprite)
				else
					key = stringformat("wario-laugh-fbz-mini-blue-%02x", (Wario.getMetronome() + (Wario.laughStyle * 0x02)))
			}
			else 
			{
				if(objA0.animation.sprite == 0x02) 
				{
					Wario.laughTimer = 0
				}
				key = stringformat("wario-fbz-mini-blue-%02x", objA0.animation.sprite)
			}
			if(Eario.spritesType)
			{
				key = stringformat("%s-png", key)
			}
			if(key != 0x00 && Renderer.hasCustomSprite(key))
			{
				bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
				Renderer.drawCustomSprite(key, px, py, Wario.getDefaultPal(), (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
				return true
			}
		}
	}
	
	//LBZ2 1st Boss
	else if(objA0.update_address == 0x073e0e)
	{
		u64 key = 0x00
		u8 animationSprite = objA0.animation.sprite
		if(objA0.animation.sprite < 0x02)
		{
			if(Wario.showRegular())
				key = stringformat("wario-blue-%02x", animationSprite)
			else
				key = stringformat("wario-laugh-blue-%02x", (Wario.getMetronome() + (Wario.laughStyle * 0x02)))
		}
		else 
		{
			if(objA0.animation.sprite == 0x02)
			{
				animationSprite += Wario.hurtAlign
				Wario.laughTimer = 0
			}
			key = stringformat("wario-blue-%02x", animationSprite)
		}
		if(Wario.spritesType)
		{
			key = stringformat("%s-png", key)
		}
		if(key != 0x00 && Renderer.hasCustomSprite(key))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, Wario.getDefaultPal(), (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			return true
		}
	}
		
	//AIZ2 Boss Intro
	else if(objA0.update_address == 0x050700)
	{
		u64 key = stringformat("wario-aiz-intro-%02x", Wario.getFreezableMetronome())
		if(Wario.spritesType)
		{
			key = stringformat("%s-png", key)
		}
		if(Renderer.hasCustomSprite(key))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, 0x10, (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			return true
		}
	}
	
	//LRZ2 Boss Intro
	else if(objA0.update_address == 0x079002 || objA0.update_address == 0x079072)
	{
		u64 key = 0x00
		if(Wario.showRegular())
			key = stringformat("wario-lrz-intro-%02x", Wario.getFreezableMetronome())
		else
			key = stringformat("wario-laugh-lrz-intro-%02x", (Wario.getMetronome() + (Wario.laughStyle * 0x02)))
		if(Wario.spritesType)
		{
			key = stringformat("%s-png", key)
		}
		if(key != 0x00 && Renderer.hasCustomSprite(key))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, 0x10, (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			return true
		}
	}
	
	//Wario outside the Eggmobile
	else if(objA0.update_address == 0x080e02 || objA0.update_address == 0x0700ea || objA0.update_address == 0x073d74 || objA0.update_address == 0x07f74c) 
	{
		if(objA0.mapping_offset != 0x186c20) //Not Eggrobo
		{
			u8 animationSprite = objA0.animation.sprite
			
			//For Misc Fixes and Tweaks Compability
			s16 scaredConfig = Wario.getScaredConfig()	
			if(objA0.animation.sprite < 0x04 && scaredConfig > 0)
			{
				if(global.zone_act == 0x0401 && (scaredConfig == 1 || scaredConfig == 3))
				{
					animationSprite += 0x04
				}
				else if((global.zone_act == 0x0b01 || global.zone_act == 0x1700) && (scaredConfig == 2 || scaredConfig == 3))
				{
					animationSprite += 0x04
				}
			}
			
			u64 key = stringformat("character-wario-blue-%02x", animationSprite)
			if(Wario.spritesType)
			{
				key = stringformat("%s-png", key)
			}
			if(Renderer.hasCustomSprite(key))
			{
				bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
				Renderer.drawCustomSprite(key, px, py, Wario.getDefaultPal(), (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
				return true
			}
		}
	}
	
	//Wario outside the Eggmobile - single lost frame in LBZ2
	//Some other sprites, like some explosions, use this update_address
	else if(objA0.update_address == 0x01abb6 && objA0.animation.sprite == 0x00 && global.zone_act == 0x0601) 
	{
		u64 key = "character-wario-blue-03"
		if(Wario.spritesType)
		{
			key = stringformat("%s-png", key)
		}
		if(Renderer.hasCustomSprite(key))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, Wario.getDefaultPal(), (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			return true
		}
	}
	
	//Bad Ending and Blue Sphere Dificulty Screen
	else if(objA0.update_address == 0x05f5b4 || objA0.update_address == 0x05fb90)
	{
		u64 key = stringformat("wario-ending-blue-%02x", objA0.animation.sprite)
		if(Wario.spritesType || objA0.update_address == 0x05f5b4)
		{
			key = stringformat("%s-png", key)
		}
		if(Renderer.hasCustomSprite(key))
		{
			u16 atex = (objA0.update_address == 0x05fb90 ? 0x00 : 0x10)
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, atex, (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			return true
		}
	}
		
	// Wario in Savedata Screen
	else if(objA0.update_address == 0x00d782)
	{
		u64 key
		if(Wario.getShineConfig() != 3)
		{
			key = stringformat("wario-delete-%x%x", objA0.animation.sprite, u8[0xffffb0b1])
			if(Wario.spritesType)
			{
				key = stringformat("%s-png", key)
			}	
		}
		else
		{
			//Try to render sprite from Misc Fixes & Tweaks
			key = stringformat("wario_dataselect_%x%x", objA0.animation.sprite, u8[0xffffb0b1])
		}
		if(Renderer.hasCustomSprite(key))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, 0x00, (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			if(Wario.isMiscFixesHere())
			{
				u64 key2 = stringformat("wario-delete-1%x", Wario.getShineConfig())
				if(Wario.spritesType)
				{
					key2 = stringformat("%s-png", key2)
				}	
				if(Renderer.hasCustomSprite(key2))
				{
					Renderer.drawCustomSprite(key2, px, py, 0x00, (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue+1)
				}
			}
			return true
		}
	}
	
	//MGZ2 Boss zoomout animation
	//objA0.animation.sprite here go from 0x04 to 0x1c
	//Write your sprite's json for "wario-zoomout-blue-04", "wario-zoomout-blue-05" ... to "wario-zoomout-blue-1c"
	else if(objA0.update_address == 0x06d060)
	{
		u64 key = stringformat("wario-zoomout-blue-%02x", objA0.animation.sprite)
		if(Renderer.hasCustomSprite(key))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, 0x10, (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue)
			return true
		}
		//Alternative usage with a single sprite and scalling done with scripting
		//Might be improved in the future
		key = stringformat("wario-zoomout-blue-%02x", Wario.getFreezableMetronome())
		if(!Renderer.hasCustomSprite(key))
			key = "wario-zoomout-blue"
		if(Renderer.hasCustomSprite(key))
		{
			s32 scale = (0x010000 - (objA0.animation.sprite * 0x800))
			if(scale < 0x002800)
				scale = 0x002800
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(key, px, py, 0x00, (objA0.render_flags & 0x01) | (prioFlag ? SPRITE_FLAG_PRIO : 0), renderQueue, 0, 0xffffffff, scale)
			return true
		}
	}
		
    else if(objA0.update_address == 0x0837b2)
    {
		u64 plateName = 0x00
		if(objA0.animation.sprite == 0x03)
		{
			plateName = stringformat("wario-goal-sign-%02x", (objA0.animation.sprite + (Wario.cdStyledGoal * 0x10)))
		}
		if(plateName != 0x00 && Renderer.hasCustomSprite(plateName))
		{
			bool prioFlag = (objA0.sprite_attributes & 0x8000) != 0
			Renderer.drawCustomSprite(plateName, px, py, Wario.getDefaultPal(), prioFlag ? SPRITE_FLAG_PRIO : 0 , renderQueue)
			return true
		}
    }
	
	else if(objA0.update_address == 0x04d9ec)
	{
		u64 key = 0x00
		if(objA0.animation.sprite == 0x07 || objA0.animation.sprite == 0x08)
		{
			key = stringformat("wario-blue-sphere-%02x", objA0.animation.sprite)
		}
		if(key != 0x00 && Renderer.hasCustomSprite(key))
		{
			Renderer.drawCustomSprite(key, px, py, 0x00, 0x00 , renderQueue)
			return true
		}
	}
	
	//System.writeDisplayLine(stringformat("%x %x",objA0.update_address,objA0.animation.sprite))
	return false
}


function void Renderer.drawCustomSprite(u64 key, s16 px, s16 py, u8 atex, u8 flags, u16 renderQueue) 
{
	//For Misc Fixes and Tweaks
	if(!Wario.legacyContinueMode) 
	{
		if(key == "wario_cont_00" || key == "wario_cont_01" || key == "wario_cont_02" || key == "wario_cont_03") 
		{
			//Ensure that the replacement sprite is flipped in the continue (Wario sprites face left by default)
			flags = flags | 0x01
			//Wario is taller than Knuckles, so this will recenter the sprite
			py -= 0x09
			if(Wario.spritesType)
			{
				u64 newKey = stringformat("%s-png", key)
				if(Renderer.hasCustomSprite(newKey))
				{
					key = newKey
				}
			}
		}
	}

	// For Mecha Mk. I Boss
	if(!Wario.disableMarkIAnimationsMod)
	{
		if(key == "msmk1_Wario") 
		{
			u64 newKey = 0x00
			if(Wario.showRegular())
				newKey = stringformat("msmk1-Wario-%02x", Wario.getFreezableMetronome())
			else
				newKey = stringformat("msmk1-Wario-Laugh-%02x", Wario.getMetronome())
			if(Renderer.hasCustomSprite(newKey))
			{
				key = newKey
				atex = Wario.getDefaultPal()
			}
		} 
		else if(key == "msmk1_Wario_Leave")
		{
			u64 newKey = System.getGlobalVariableValueByName("MSMKI.Defeated") ? "msmk1-Wario-Defeat" : "msmk1-Wario-Hurt"
			if(Renderer.hasCustomSprite(newKey))
			{
				Wario.laughTimer = 0
				key = newKey
				atex = Wario.getDefaultPal()
			}
		}
	}

	base.Renderer.drawCustomSprite(key, px, py, atex, flags, renderQueue)
}

//For LBZ Eggman Fleeing
function void Renderer.drawCustomSprite(u64 key, s16 px, s16 py, u8 atex, u8 flags, u16 renderQueue, u8 angle, u32 tint, s32 scale)
{
	if(!Wario.spritesType)
	{
		if(key == "wariolost1" || key == "wariolost2" || key == "wariolost3" || key == "wariolost4" || key == "wariolost5" || key == "wariolost6")
		{
			u64 newKey = stringformat("%s-bmp", key)
			if(Renderer.hasCustomSprite(newKey))
			{
				key = newKey
				atex = 0x00
			}
		}
	}
	base.Renderer.drawCustomSprite(key, px, py, atex, flags, renderQueue, angle, tint, scale)
}

function bool Standalone.onWriteToSpriteTable(s16 px, s16 py, u16 renderQueue)
{
	if(Wario.onWriteToSpriteTable(px, py,renderQueue))
		return true
	else if(base.Standalone.onWriteToSpriteTable(px, py, renderQueue))
		return true
	else
		return false
}

function u64 Monitor.getIconSpriteKey(u8 type)
{
	if (type == 0x02 && wario.disableMonitorReplacement != 1)
	{
		return "monitor_icon_wario"
	}
	return base.Monitor.getIconSpriteKey(type)
}

function bool Wario.showRegular()
{
	bool gameOverCondition = ((global.time_over == 0 && lives_counter > 0) || Wario.disableDeadLaugh == 1)
	return (Wario.laughTimer <= 0 && gameOverCondition)
}

function void Wario.decreaseTimer()
{
	if(Wario.laughTimer > 0) 
	{
		u16 fc = level.framecounter
		if(Wario.lastFrame != fc)
		{
			Wario.lastFrame = fc
			--Wario.laughTimer
		}
	}
}

//# address-hook(0x010a94) end(0x010ae8)
function void Character.BaseUpdate.Sonic()
{
	if(isMainCharacter(CHARACTER_SONIC))
	{
		Wario.decreaseTimer()
	}
	base.Character.BaseUpdate.Sonic()
}

//# address-hook(0x01365c) end(0x0136b8)
function void Character.BaseUpdate.Tails()
{
	if(isMainCharacter(CHARACTER_TAILS))
	{
		Wario.decreaseTimer()
	}
	base.Character.BaseUpdate.Tails()
}

//# address-hook(0x016444) end(0x016498)
function void Character.BaseUpdate.Knuckles()
{
	if(isMainCharacter(CHARACTER_KNUCKLES))
	{
		Wario.decreaseTimer()
	}
	base.Character.BaseUpdate.Knuckles()
}

//# address-hook(0x010294) end(0x010364)
function void Character.GettingHurt()
{
	base.Character.GettingHurt()
	//Wario.laughTimer < 64 is to avoid 2nd player Tails cutting death laughs short
	if(char.state == char.state.GOT_HURT && Wario.laughTimer < 64 && Wario.disableHurtLaugh != 1)
	{
		Wario.laughTimer = 64
	}
}

function void Wario.DeathLaugh()
{
	if(char.state == char.state.DIED && Wario.disableDeadLaugh != 1)
	{
		if(A0 == 0xffffb000) //This is true if it's the first player dying
		{
			Wario.laughTimer = 176
		}
		else if(Wario.laughTimer < 64) //To avoid 2nd player Tails cutting death laughs short
		{
			Wario.laughTimer = 64 //if 2nd Player dies it's regular laugh time
		}
	}
}

//# address-hook(0x01036e) end(0x0103b8)
function void Character.Die_internal()
{
	base.Character.Die_internal()
	Wario.DeathLaugh()
}

//# address-hook(0x010366) end(0x01036c)
function void Character.Die()
{
	base.Character.Die()
	Wario.DeathLaugh()
}

function void Wario.KnucklesTasedLaugh()
{
	//For HPZ
	if(Wario.disableHurtLaugh != 1)
		if(Wario.disableEventLaugh == 1)
		{
			Wario.laughTimer = 64
		}
}

//# address-hook(0x0654fa) end(0x06554a)
function void fn0654fa()
{
	Wario.KnucklesTasedLaugh()
	base.fn0654fa()
}

//# address-hook(0x065564) end(0x0655a6)
function void fn065564()
{
